[flake8]
max-line-length = 100
extend-ignore = E203, E266, E501, W503, F401, F841, F541
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    build,
    dist,
    *.egg-info,
    migrations,
    alembic,
    node_modules,
    .mypy_cache,
    .pytest_cache
per-file-ignores =
    __init__.py:F401
    tests/*:F401,F841
max-complexity = 15
